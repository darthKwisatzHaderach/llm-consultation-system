# Корневой файл: скопировать в .env рядом с docker-compose.yml и заполнить значения.
# Остальное (REDIS_URL, RABBITMQ_URL, AUTH_SERVICE_URL, модель OpenRouter и т.п.) задано в docker-compose.yml.

# Один и тот же ключ для подписи JWT в auth и проверки в bot; длинная случайная строка.
JWT_SECRET=

# От @BotFather после /newbot (формат 123456789:AAH...)
TELEGRAM_BOT_TOKEN=

# Ключ API с https://openrouter.ai/keys (нужен воркеру Celery).
OPENROUTER_API_KEY=
